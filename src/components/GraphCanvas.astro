---
// Egocentric view: a focus node + its immediate neighbours, never the whole graph.
// Edges follow the design system: computed (compatibility) vs authored (relations);
// bridged edges are computed + dotted + a "via" label. Renders an SVG (desktop) and
// a vertical reflow column (mobile / no-JS). Clicking a neighbour recentres.
import type { Graph } from '../lib/graph';
interface Props { graph: Graph; focusId: string }
const { graph, focusId } = Astro.props;
const base = import.meta.env.BASE_URL;

const node = (id: string) => graph.nodes.find((n) => n.id === id);
const nameOf = (id: string) => node(id)?.canonical ?? id;
const diff = (id: string) => Math.min(node(id)?.difficulty ?? 2, 4);
const adj = graph.adjacency[focusId] ?? { leadsTo: [], comesFrom: [], related: [] };

type N = { id: string; cls: 'direct' | 'bridged' | 'authored'; via?: string; dir: 'out' | 'in' | 'rel' };
const seen = new Set<string>([focusId]);
const neighbours: N[] = [];
const add = (n: N) => { if (!seen.has(n.id)) { seen.add(n.id); neighbours.push(n); } };
// Authored (curated) relations win over computed edges to the same node — they're the louder meaning.
for (const e of adj.related) add({ id: e.to, cls: 'authored', dir: 'rel' });
for (const e of adj.leadsTo) add({ id: e.to, cls: e.via ? 'bridged' : 'direct', via: e.via, dir: 'out' });
for (const e of adj.comesFrom) add({ id: e.from, cls: e.via ? 'bridged' : 'direct', via: e.via, dir: 'in' });

const W = 760, H = 470, cx = W / 2, cy = H / 2, R = 165;
const shown = neighbours.slice(0, 12);
const placed = shown.map((n, i) => {
  const a = (2 * Math.PI * i) / Math.max(shown.length, 1) - Math.PI / 2;
  return { ...n, x: Math.round(cx + R * Math.cos(a)), y: Math.round(cy + R * Math.sin(a)) };
});

const leadsTo = neighbours.filter((n) => n.dir === 'out');
const comesFrom = neighbours.filter((n) => n.dir === 'in');
const related = neighbours.filter((n) => n.dir === 'rel');
---

<section class="graph">
  <div class="canvas-frame">
    <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={`Figures connected to ${nameOf(focusId)}`}>
      <defs>
        <marker id="authArrow" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto">
          <path d="M0 0 L9 4.5 L0 9 Z" class="arrow-a" />
        </marker>
      </defs>

      {placed.map((n) => {
        const mx = (cx + n.x) / 2, my = (cy + n.y) / 2;
        const authored = n.cls === 'authored';
        return (
          <g>
            <path
              class={authored ? 'edge-authored edge-flow' : 'edge-computed'}
              style={n.cls === 'bridged' ? 'stroke-dasharray:2 5' : n.cls === 'direct' ? 'stroke-dasharray:none;opacity:1' : ''}
              d={`M${cx} ${cy} Q ${mx} ${my} ${n.x} ${n.y}`}
              marker-end={authored ? 'url(#authArrow)' : undefined}
            />
            {n.via && <text class="via-label" x={mx} y={my - 4}>via {nameOf(n.via)}</text>}
          </g>
        );
      })}

      {placed.map((n) => (
        <a href={`${base}figures/${n.id}/`} aria-label={nameOf(n.id)}>
          <ellipse class="graph-node-blob" cx={n.x} cy={n.y} rx="40" ry="32" fill={`var(--diff-${diff(n.id)})`} stroke={`color-mix(in oklch, var(--diff-${diff(n.id)}) 55%, black)`} stroke-width="1.5" />
          <text class="node-label" x={n.x} y={n.y + 1} fill={`var(--on-diff-${diff(n.id)})`}>{nameOf(n.id)}</text>
          <text class="node-meta" x={n.x} y={n.y + 16} fill={`var(--on-diff-${diff(n.id)})`}>L{node(n.id)?.difficulty}</text>
        </a>
      ))}

      <ellipse class="graph-node-blob" cx={cx} cy={cy} rx="48" ry="38" fill={`var(--diff-${diff(focusId)})`} stroke="var(--focus)" stroke-width="3" />
      <text class="node-label" x={cx} y={cy + 1} fill={`var(--on-diff-${diff(focusId)})`}>{nameOf(focusId)}</text>
    </svg>
    <span class="frame-caption">{nameOf(focusId)} · click a neighbour to walk</span>
  </div>

  <div class="gc-path">
    <span class="focus-node">{nameOf(focusId)}</span>
    {comesFrom.length > 0 && (
      <div class="group">
        <h3>comes from</h3>
        {comesFrom.map((n) => (
          <a class="node-link" href={`${base}figures/${n.id}/`}>{nameOf(n.id)}{n.via && <span class="via">via {nameOf(n.via)}</span>}</a>
        ))}
      </div>
    )}
    {leadsTo.length > 0 && (
      <div class="group">
        <h3>leads to</h3>
        {leadsTo.map((n) => (
          <a class="node-link" href={`${base}figures/${n.id}/`}>{nameOf(n.id)}{n.via && <span class="via">small adjustment · via {nameOf(n.via)}</span>}</a>
        ))}
      </div>
    )}
    {related.length > 0 && (
      <div class="group">
        <h3>related</h3>
        {related.map((n) => (
          <a class="node-link" href={`${base}figures/${n.id}/`}>{nameOf(n.id)}</a>
        ))}
      </div>
    )}
  </div>

  <div class="legend">
    <span class="l-direct"><i></i>direct</span>
    <span class="l-bridged"><i></i>small adjustment (via a primitive)</span>
    <span class="l-authored"><i></i>related (authored)</span>
  </div>
</section>
